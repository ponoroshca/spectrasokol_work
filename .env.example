# ─── Окружение shopbot ───────────────────────────────────────────────
# Скопируй в .env и заполни. .env в git НЕ коммитится.

# Секрет Flask-сессий админки. ОБЯЗАТЕЛЬНО задать (иначе при каждом рестарте
# сессии сбрасываются). Сгенерировать: python3 -c "import secrets;print(secrets.token_hex(32))"
SHOPBOT_SECRET_KEY=

# (опц.) авто-reload веб-аппа при разработке
# WEBAPP_RELOAD=0

# ─── ВАЖНО ───────────────────────────────────────────────────────────
# Остальное (токен бота, платёжные ключи YooKassa/CryptoBot/и т.д., адрес и
# токен панели Remnawave, домен мини-аппа, тексты/брендинг) НЕ здесь, а в
# АДМИН-ПАНЕЛИ после первого запуска (Настройки). БД создаётся автоматически
# при старте (пустая, схема ставится сама) — юзеров добавляй через бота.
